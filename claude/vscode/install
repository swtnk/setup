#!/usr/bin/env bash
# ──────────────────────────────────────────────────────────────────────────────
# Claude Code for VS Code — Project Setup Installer
# https://swetanksubham.com/setup/claude/vscode
#
# Usage:
#   curl -fsSL https://swetanksubham.com/setup/claude/vscode/install | bash
#   curl -fsSL https://swetanksubham.com/setup/claude/vscode/install | bash -s -- --copilot
#   curl -fsSL https://swetanksubham.com/setup/claude/vscode/install | bash -s -- --global
#
# Flags:
#   --copilot     Also set up GitHub Copilot instructions (.github/)
#   --global      Install to ~/.claude/ (global, applies to all projects)
#   --force       Overwrite existing files without prompting
#   --no-detect   Skip language auto-detection, install all language rules
#   --help        Show help
# ──────────────────────────────────────────────────────────────────────────────

set -euo pipefail

# ── Constants ─────────────────────────────────────────────────────────────────

readonly VERSION="1.0.0"
readonly INSTALLER_URL="https://swetanksubham.com/setup/claude/vscode"

# ── Colors & Formatting ──────────────────────────────────────────────────────

if [[ -t 1 ]] && [[ "${NO_COLOR:-}" != "1" ]]; then
    readonly BOLD="\033[1m"
    readonly DIM="\033[2m"
    readonly RESET="\033[0m"
    readonly GREEN="\033[38;2;80;200;120m"
    readonly BLUE="\033[38;2;100;149;237m"
    readonly YELLOW="\033[38;2;255;200;87m"
    readonly RED="\033[38;2;255;99;71m"
    readonly CYAN="\033[38;2;0;206;209m"
    readonly PURPLE="\033[38;2;178;102;255m"
    readonly WHITE="\033[38;2;255;255;255m"
    readonly GRAY="\033[38;2;128;128;128m"
    readonly CHECK="${GREEN}✓${RESET}"
    readonly CROSS="${RED}✗${RESET}"
    readonly ARROW="${CYAN}→${RESET}"
    readonly DOT="${GRAY}·${RESET}"
else
    readonly BOLD="" DIM="" RESET=""
    readonly GREEN="" BLUE="" YELLOW="" RED="" CYAN="" PURPLE="" WHITE="" GRAY=""
    readonly CHECK="✓" CROSS="✗" ARROW="→" DOT="·"
fi

# ── CLI State ─────────────────────────────────────────────────────────────────

SETUP_COPILOT=false
GLOBAL_INSTALL=false
FORCE_OVERWRITE=false
AUTO_DETECT=true

# ── Helpers ───────────────────────────────────────────────────────────────────

info()    { printf "  ${DOT} %b\n" "$1"; }
success() { printf "  ${CHECK} %b\n" "$1"; }
warn()    { printf "  ${YELLOW}!${RESET} %b\n" "$1"; }
error()   { printf "  ${CROSS} %b\n" "$1" >&2; }
step()    { printf "\n  ${ARROW} ${BOLD}%b${RESET}\n" "$1"; }

banner() {
    printf "\n"
    printf "  ${PURPLE}${BOLD}╔═══════════════════════════════════════════════╗${RESET}\n"
    printf "  ${PURPLE}${BOLD}║${RESET}  ${WHITE}${BOLD}Claude Code${RESET} ${GRAY}for VS Code${RESET}  ${DIM}v${VERSION}${RESET}            ${PURPLE}${BOLD}║${RESET}\n"
    printf "  ${PURPLE}${BOLD}║${RESET}  ${DIM}Project Architect Setup${RESET}                      ${PURPLE}${BOLD}║${RESET}\n"
    printf "  ${PURPLE}${BOLD}╚═══════════════════════════════════════════════╝${RESET}\n"
    printf "\n"
}

show_help() {
    banner
    printf "  ${BOLD}Usage:${RESET}\n"
    printf "    curl -fsSL %s/install | bash\n" "${INSTALLER_URL}"
    printf "    curl -fsSL %s/install | bash -s -- [flags]\n\n" "${INSTALLER_URL}"
    printf "  ${BOLD}Flags:${RESET}\n"
    printf "    --copilot     Also set up GitHub Copilot instructions\n"
    printf "    --global      Install to ~/.claude/ (applies to all projects)\n"
    printf "    --force       Overwrite existing files without prompting\n"
    printf "    --no-detect   Skip language detection, install all rules\n"
    printf "    --help        Show this help message\n\n"
    exit 0
}

write_file() {
    local filepath="$1"
    local content="$2"
    local label="${3:-$filepath}"

    local dir
    dir="$(dirname "${filepath}")"
    mkdir -p "${dir}"

    if [[ -f "${filepath}" ]] && [[ "${FORCE_OVERWRITE}" == false ]]; then
        warn "Exists: ${DIM}${label}${RESET} ${GRAY}(use --force to overwrite)${RESET}"
        return 0
    fi

    printf '%s\n' "${content}" > "${filepath}"
    success "Created: ${DIM}${label}${RESET}"
}

append_line() {
    local filepath="$1"
    local line="$2"
    local label="${3:-$filepath}"

    if [[ -f "${filepath}" ]]; then
        if grep -qxF "${line}" "${filepath}" 2>/dev/null; then
            info "Already in ${DIM}${label}${RESET}: ${GRAY}${line}${RESET}"
            return 0
        fi
        printf '\n%s\n' "${line}" >> "${filepath}"
        success "Updated: ${DIM}${label}${RESET} ${GRAY}+ ${line}${RESET}"
    else
        printf '%s\n' "${line}" > "${filepath}"
        success "Created: ${DIM}${label}${RESET} ${GRAY}with ${line}${RESET}"
    fi
}

# ── Language Detection ────────────────────────────────────────────────────────

detect_languages() {
    local dir="$1"
    local -a found=()

    # Python
    if [[ -f "${dir}/pyproject.toml" ]] || \
       [[ -f "${dir}/setup.py" ]] || \
       [[ -f "${dir}/requirements.txt" ]] || \
       [[ -f "${dir}/Pipfile" ]] || \
       [[ -f "${dir}/poetry.lock" ]] || \
       compgen -G "${dir}/**/*.py" > /dev/null 2>&1 || \
       compgen -G "${dir}/*.py" > /dev/null 2>&1; then
        found+=("python")
    fi

    # Java
    if [[ -f "${dir}/pom.xml" ]] || \
       [[ -f "${dir}/build.gradle" ]] || \
       [[ -f "${dir}/build.gradle.kts" ]] || \
       [[ -d "${dir}/src/main/java" ]] || \
       compgen -G "${dir}/**/*.java" > /dev/null 2>&1; then
        found+=("java")
    fi

    # Rust
    if [[ -f "${dir}/Cargo.toml" ]] || \
       compgen -G "${dir}/**/*.rs" > /dev/null 2>&1 || \
       compgen -G "${dir}/src/*.rs" > /dev/null 2>&1; then
        found+=("rust")
    fi

    # TypeScript
    if [[ -f "${dir}/tsconfig.json" ]] || \
       compgen -G "${dir}/**/*.ts" > /dev/null 2>&1 || \
       compgen -G "${dir}/**/*.tsx" > /dev/null 2>&1 || \
       compgen -G "${dir}/src/*.ts" > /dev/null 2>&1; then
        found+=("typescript")
    fi

    # Go
    if [[ -f "${dir}/go.mod" ]] || \
       compgen -G "${dir}/**/*.go" > /dev/null 2>&1 || \
       compgen -G "${dir}/*.go" > /dev/null 2>&1; then
        found+=("go")
    fi

    # C/C++
    if [[ -f "${dir}/CMakeLists.txt" ]] || \
       [[ -f "${dir}/Makefile" ]] || \
       compgen -G "${dir}/**/*.c" > /dev/null 2>&1 || \
       compgen -G "${dir}/**/*.cpp" > /dev/null 2>&1 || \
       compgen -G "${dir}/**/*.h" > /dev/null 2>&1; then
        found+=("c_cpp")
    fi

    printf '%s\n' "${found[@]}"
}

# ── Embedded File Contents ────────────────────────────────────────────────────
# All rule files are embedded here so the installer is fully self-contained.
# No additional downloads required.

generate_claude_md() {
cat << 'CLAUDE_MD_EOF'
# Project Architect Instructions

You are an architecture-first code generator. Before writing a single line of code, you must fully understand the project. This file defines your coding principles, workflow, and conventions.

---

## Step 0: Deep Dive First (Mandatory, Every Time)

**Before making any changes, build a complete understanding of the project.**

### For Existing Projects

Walk through the entire codebase systematically before making any changes:

1. Scan the full directory tree: understand every directory's purpose, module organization, what lives where
2. Read all key files: entry points, configs, build configs, constants/config files, env files, CI configs, Dockerfiles, test setup, dependency manifests
3. Trace the architecture: how components connect, data flow, dependency injection patterns, error handling, logging, validation, routing
4. Catalog coding conventions: naming style, import ordering, comment style, indentation, quote style, file naming patterns, module structure, abstraction patterns
5. Map constants and config: find all existing constants files, env files, config objects. Understand how configuration flows through the system.
6. Identify the full tech stack: frameworks, libraries, build tools, test frameworks, linters, formatters, and versions
7. Write everything to `.claude/context/` (see Project Memory section below)
8. **Match every convention exactly.** Generated code must look like the existing team wrote it.

### For New Projects

1. Understand requirements thoroughly. Ask clarifying questions if anything is ambiguous.
2. Design the architecture: components, interfaces, data flow, module boundaries
3. Decide conventions based on language best practices and the principles below
4. Plan constants/config structure
5. Choose dependencies with justification
6. Populate `.claude/context/` with all findings before generating any project code

### Resuming Work

1. Read every file in `.claude/context/` first. Do not skip this.
2. Check `progress.md` and `tasklist.md` to understand where things left off.
3. If the user mentions changes made outside these conversations, re-scan affected areas and update context files.

---

## Universal Coding Principles (Non-Negotiable)

### 1. SOLID Principles Always
Single Responsibility, Open/Closed, Liskov Substitution, Interface Segregation, Dependency Inversion. These are the baseline, not aspirational.

### 2. Immutability by Default
Every variable, field, parameter, and data structure is immutable unless mutation is explicitly required and justified.
- Rust: default ownership, prefer `&` borrows, use `mut` only when needed
- Python: prefer `tuple` over `list` for fixed data, use `Final` from typing, frozen dataclasses
- Java: `final` on every variable/field/parameter, `@Value` classes via Lombok
- TypeScript: `const`, `readonly`, `Readonly<T>`, `as const`
- Go: minimize pointer usage when value semantics suffice
- Other languages: apply the closest equivalent

### 3. Zero Hardcoded Values
All constants, magic numbers, configuration values, URLs, timeouts, feature flags go into a centralized constants or config file. Every other file references these through imports. Group and document clearly.

### 4. No Raw Nulls
Use `Optional`/`Option`/`Result` types everywhere. Never return or accept null/None/nil where an Optional type exists.

### 5. Prefer Standard Library Utilities
If the language provides a utility, use it. Do not reimplement `Objects.isNull`, `Comparator.comparing`, `itertools`, `std::cmp`, or anything the platform already offers.

---

## Language-Specific Standards

### Python
- Type hints on everything: all function parameters, return types, variable annotations
- `Protocol` classes for structural subtyping
- Full `typing` module usage: `Optional`, `Final`, `TypeAlias`, `TypeVar`, `Generic`, `Literal`, `TypedDict`, `Annotated`, `overload`
- Frozen dataclasses or `NamedTuple` for data containers
- `from __future__ import annotations`

### Java
- Null-safety is paramount: `java.util.Optional` for absent values, `Objects.isNull()`, `Objects.nonNull()`, `Objects.requireNonNull()`
- Lombok annotations:
  - `@Value` for immutable data classes (preferred over `@Data`)
  - `@Builder` on classes and records
  - `@NonNull` on parameters and fields
  - `@Getter` + `@RequiredArgsConstructor` on enums
  - `@Slf4j` for logging
- Records with `@Builder` for simple data carriers
- Standard utilities: `Comparator.comparing()`, Stream API, `Collections.unmodifiable*()`, `Map.of()`, `List.of()`

### Rust
- Lean into ownership. Prefer borrowing over cloning.
- `Result<T, E>` for fallible operations with meaningful error types (`thiserror` or `anyhow`)
- Derive `Clone`, `Debug`, `PartialEq` as appropriate. `#[non_exhaustive]` on public enums/structs.
- `impl Trait` in argument position for flexibility
- Rust 2024 edition idioms

### TypeScript
- Strict mode always (`"strict": true`)
- `const` by default, `let` only when reassignment is unavoidable, never `var`
- `readonly` on object properties, `Readonly<T>`, `ReadonlyArray<T>`
- Explicit return types on public functions
- Discriminated unions over loose string types

### Go
- Minimize pointer usage when value semantics suffice
- Return errors explicitly, never ignore them
- Use `errors.Is()` and `errors.As()` for error checking
- Prefer composition over inheritance via struct embedding

### Other Languages
Apply the equivalent immutability, null-safety, and type-safety idioms.

---

## Project Memory: `.claude/context/`

Every project gets a `.claude/context/` directory at the project root. This is the persistent lookup reference. Build it once, keep it updated, always consult it.

### Context Files

| File | Purpose |
|---|---|
| `architecture.md` | System design, component relationships, data flow, design decisions and rationale |
| `conventions.md` | Coding patterns, naming conventions, file organization, import ordering, error handling patterns |
| `progress.md` | What's complete, in progress, and pending |
| `constants-map.md` | Where config/constants files live, what they contain, how to add new ones |
| `dependencies.md` | Key libraries, why chosen, version constraints, compatibility notes |
| `tasklist.md` | All planned work items, ordered by priority/dependency, with checkboxes |
| `plan.md` | Project plan: phases, milestones, delivery strategy, risk areas, open questions |

### Rules
- Add `.claude/context/` to `.gitignore` and `.dockerignore`
- Read before writing: always consult context files before starting any work
- Never delete information: append and update. Document reversals with reasons.

---

## Adaptive Workflow

### Scale Assessment
- **Small (< 10 files)**: scaffold in one or two passes
- **Medium (10-30 files)**: break into logical modules, generate module by module
- **Large (30+ files)**: full phased approach with planning

### Always Include When Relevant
- Test scaffolding (unit + integration) mirroring source structure
- Database schema and migrations using the ecosystem's standard tool
- Docker: multi-stage builds, non-root user, docker-compose for local dev
- Constants/config documented in `constants-map.md`

### Quality Checklist
Before presenting code:
- No hardcoded values outside constants/config files
- All variables/fields immutable unless mutation is justified
- Optional/Result types used instead of raw nulls
- Standard library utilities used where available
- SOLID principles followed
- Language-specific standards met
- `.claude/context/` created/updated
- Tests included where appropriate
CLAUDE_MD_EOF
}

generate_rule_general() {
cat << 'RULE_EOF'
---
paths:
  - "**"
---

# General Project Architect Rules

## Deep Dive First
Before making any changes to this project, read all files in `.claude/context/` if they exist. If they don't exist, perform a full codebase analysis and create them before writing any code.

## Project Memory
Maintain `.claude/context/` with these files, updated after every significant change:
- `architecture.md` - system design, component relationships, data flow, design decisions
- `conventions.md` - coding patterns discovered or decided, with file references
- `progress.md` - what's complete, in progress, pending
- `constants-map.md` - where config/constants live, what they contain
- `dependencies.md` - key libraries, why chosen, versions
- `tasklist.md` - planned work items with checkboxes
- `plan.md` - project plan, phases, milestones

## Universal Principles
- SOLID principles: every file has one clear responsibility
- Immutability by default: all variables/fields immutable unless mutation is justified
- Zero hardcoded values: use centralized constants/config files
- No raw nulls: use Optional/Result/Option types
- Prefer standard library utilities over custom reimplementations
- For existing codebases: match every existing convention exactly

## Existing Codebase Rules
When modifying an existing project, match: indentation, naming style, quote style, import ordering, comment style, abstraction patterns, error handling patterns. The generated code must look like the existing team wrote it.
RULE_EOF
}

generate_rule_python() {
cat << 'RULE_EOF'
---
paths:
  - "**/*.py"
---

# Python Coding Standards

- Type hints on ALL function parameters, return types, and variable annotations. No untyped public functions.
- Use `Protocol` classes for structural subtyping (prefer over ABCs when inheritance isn't needed).
- Full `typing` module usage: `Optional`, `Final`, `TypeAlias`, `TypeVar`, `Generic`, `Literal`, `TypedDict`, `Annotated`, `overload`.
- Use `from __future__ import annotations` at the top of every file.
- Frozen `@dataclass(frozen=True)` or `NamedTuple` for data containers. Mutable classes need explicit justification.
- Prefer `tuple` over `list` for fixed collections. Use `Final` for constants.
- All constants go in a centralized config/constants module. Never hardcode values inline.
- Use `Optional[X]` instead of `X | None` for clarity (unless project convention differs).
- Immutability by default: avoid reassignment, prefer creating new values.
RULE_EOF
}

generate_rule_java() {
cat << 'RULE_EOF'
---
paths:
  - "**/*.java"
---

# Java Coding Standards

- Null-safety is paramount: use `java.util.Optional` for any value that might be absent.
- Use `java.util.Objects.isNull()`, `Objects.nonNull()`, `Objects.requireNonNull()` instead of manual null checks.
- Use static standard library utilities (`Comparator.comparing()`, `Stream` API, `Collections.unmodifiable*()`, `Map.of()`, `List.of()`) instead of reimplementing them.
- Lombok annotations:
  - `@Value` for immutable data classes (preferred over `@Data`)
  - `@Builder` on classes AND records
  - `@NonNull` on parameters and fields that must not be null
  - `@Getter` + `@RequiredArgsConstructor` on enums
  - `@Slf4j` for logging
- `final` on every variable, field, and parameter by default. Remove only when mutation is explicitly justified.
- Records with `@Builder` for simple data carriers.
- All constants in a centralized constants class or config. Never hardcode values inline.
- SOLID principles: one responsibility per class, program to interfaces, inject dependencies.
RULE_EOF
}

generate_rule_rust() {
cat << 'RULE_EOF'
---
paths:
  - "**/*.rs"
---

# Rust Coding Standards

- Lean into ownership. Prefer borrowing (`&`/`&mut`) over cloning.
- Use `mut` only when mutation is explicitly required and justified.
- `Result<T, E>` for all fallible operations. Define meaningful error types using `thiserror` or `anyhow`.
- Never use `.unwrap()` or `.expect()` in library/production code. Use `?` operator or explicit matching.
- Derive `Clone`, `Debug`, `PartialEq` as appropriate. Use `#[non_exhaustive]` on public enums/structs.
- Prefer `impl Trait` in argument position for flexibility.
- Use Rust 2024 edition idioms.
- All constants in a centralized `constants.rs` or `config.rs` module.
- Prefer `const` over `static` where possible. Use `once_cell` / `LazyLock` for runtime constants.
- SOLID: traits for abstraction, small focused modules, dependency injection via trait objects or generics.
RULE_EOF
}

generate_rule_typescript() {
cat << 'RULE_EOF'
---
paths:
  - "**/*.ts"
  - "**/*.tsx"
---

# TypeScript Coding Standards

- Strict mode always: `"strict": true` in tsconfig.
- `const` by default. `let` only when reassignment is unavoidable. Never `var`.
- `readonly` on all object properties. Use `Readonly<T>`, `ReadonlyArray<T>`.
- Explicit return types on all public/exported functions.
- Discriminated unions over loose string types or enums.
- Use `undefined` over `null` where possible. Prefer optional chaining (`?.`) and nullish coalescing (`??`).
- All constants in a centralized `constants.ts` or `config.ts`. Never hardcode values inline.
- Use `as const` for literal type narrowing.
- SOLID: interfaces for contracts, small focused modules, dependency injection.
- Prefer `unknown` over `any`. If `any` is needed, add a comment explaining why.
RULE_EOF
}

generate_rule_go() {
cat << 'RULE_EOF'
---
paths:
  - "**/*.go"
---

# Go Coding Standards

- Return errors explicitly. Never ignore error return values.
- Use `errors.Is()` and `errors.As()` for error checking, not string comparison.
- Define custom error types with `fmt.Errorf("context: %w", err)` for wrapping.
- Minimize pointer usage when value semantics suffice. Pointers only when mutation is required or structs are large.
- Prefer composition via struct embedding over deep interface hierarchies.
- Use `const` blocks for related constants. Group by purpose.
- All configuration in a centralized config struct, loaded from environment or file. Never hardcode values.
- Use `context.Context` for cancellation and deadline propagation.
- Table-driven tests as the default testing pattern.
- Prefer short, focused interfaces (1-3 methods). Accept interfaces, return structs.
RULE_EOF
}

generate_rule_c_cpp() {
cat << 'RULE_EOF'
---
paths:
  - "**/*.c"
  - "**/*.cpp"
  - "**/*.h"
  - "**/*.hpp"
---

# C/C++ Coding Standards

- Use `const` by default on all variables, parameters, and pointers where mutation is not needed.
- C++: prefer `std::unique_ptr` and `std::shared_ptr` over raw pointers. RAII for all resource management.
- C++: use `std::optional` for values that might be absent. Avoid raw null checks.
- C++: prefer `constexpr` over `#define` for compile-time constants.
- C: use `const` qualifiers liberally. Group constants in header files.
- All magic numbers and configuration in dedicated header/config files.
- Use `static` for file-scoped functions and variables.
- C++: prefer `enum class` over plain `enum`.
- C++: use `std::string_view` for non-owning string references.
- Use the standard library algorithms (`<algorithm>`, `<numeric>`) instead of hand-rolled loops where applicable.
RULE_EOF
}

generate_copilot_instructions() {
    # Same content as CLAUDE.md but with Copilot-specific header
    printf "# Copilot Custom Instructions\n\n"
    printf "These instructions apply to all Copilot interactions in this workspace.\n"
    printf "For Claude agent sessions, these are automatically loaded.\n\n"
    generate_claude_md | tail -n +2
}

convert_rule_to_copilot() {
    # Convert paths: format to applyTo: format for Copilot
    local content="$1"
    printf '%s\n' "${content}" | sed 's/^paths:$/applyTo:/' | sed 's/^  - "\(.*\)"$/  - "\1"/'
}

# ── Main Install Logic ────────────────────────────────────────────────────────

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --copilot)    SETUP_COPILOT=true ;;
            --global)     GLOBAL_INSTALL=true ;;
            --force)      FORCE_OVERWRITE=true ;;
            --no-detect)  AUTO_DETECT=false ;;
            --help|-h)    show_help ;;
            *)
                error "Unknown flag: $1"
                printf "  Run with --help for usage.\n"
                exit 1
                ;;
        esac
        shift
    done
}

main() {
    parse_args "$@"
    banner

    # ── Determine install target ──────────────────────────────────────────

    local target_dir
    if [[ "${GLOBAL_INSTALL}" == true ]]; then
        target_dir="${HOME}/.claude"
        step "Installing globally to ${CYAN}~/.claude/${RESET}"
    else
        target_dir="$(pwd)"
        step "Setting up project at ${CYAN}${target_dir}${RESET}"
    fi

    # ── Detect languages ──────────────────────────────────────────────────

    local -a languages=()

    if [[ "${GLOBAL_INSTALL}" == true ]] || [[ "${AUTO_DETECT}" == false ]]; then
        languages=("python" "java" "rust" "typescript" "go" "c_cpp")
        info "Installing all language rules"
    else
        step "Detecting project languages"

        mapfile -t languages < <(detect_languages "${target_dir}")

        if [[ ${#languages[@]} -eq 0 ]]; then
            warn "No languages detected. Installing all rules."
            languages=("python" "java" "rust" "typescript" "go" "c_cpp")
        else
            for lang in "${languages[@]}"; do
                local display_name="${lang}"
                case "${lang}" in
                    c_cpp) display_name="C/C++" ;;
                    typescript) display_name="TypeScript" ;;
                    *) display_name="$(echo "${lang}" | sed 's/./\U&/')" ;;
                esac
                success "Found: ${BOLD}${display_name}${RESET}"
            done
        fi
    fi

    # ── Create CLAUDE.md ──────────────────────────────────────────────────

    step "Creating Claude Code configuration"

    if [[ "${GLOBAL_INSTALL}" == true ]]; then
        mkdir -p "${target_dir}"
        write_file "${target_dir}/CLAUDE.md" "$(generate_claude_md)" "~/.claude/CLAUDE.md"
    else
        write_file "${target_dir}/CLAUDE.md" "$(generate_claude_md)" "CLAUDE.md"
    fi

    # ── Create .claude/rules/ ─────────────────────────────────────────────

    step "Installing coding rules"

    local rules_dir="${target_dir}/.claude/rules"
    mkdir -p "${rules_dir}"

    write_file "${rules_dir}/general.md" "$(generate_rule_general)" ".claude/rules/general.md"

    for lang in "${languages[@]}"; do
        local generator_fn="generate_rule_${lang}"
        if declare -f "${generator_fn}" > /dev/null 2>&1; then
            write_file "${rules_dir}/${lang}.md" "$(${generator_fn})" ".claude/rules/${lang}.md"
        fi
    done

    # ── Create .claude/context/ ───────────────────────────────────────────

    if [[ "${GLOBAL_INSTALL}" == false ]]; then
        step "Initializing project memory"

        local context_dir="${target_dir}/.claude/context"
        mkdir -p "${context_dir}"

        local context_readme
        context_readme="$(cat << 'CTX_EOF'
# .claude/context/

This directory is Claude's project memory. It persists understanding across conversations
so Claude never has to re-analyze the codebase from scratch.

## Files

| File | Purpose |
|---|---|
| `architecture.md` | System design, component relationships, data flow |
| `conventions.md` | Coding patterns, naming conventions, style rules |
| `progress.md` | What's complete, in progress, pending |
| `constants-map.md` | Where config/constants live, what they contain |
| `dependencies.md` | Key libraries, why chosen, version constraints |
| `tasklist.md` | Planned work items with checkboxes |
| `plan.md` | Project plan, phases, milestones |

These files are auto-generated and maintained by Claude during development.
This directory is excluded from git and Docker builds.
CTX_EOF
)"
        write_file "${context_dir}/README.md" "${context_readme}" ".claude/context/README.md"
        success "Ready: ${DIM}.claude/context/${RESET} ${GRAY}(Claude will populate on first use)${RESET}"
    fi

    # ── Update .gitignore ─────────────────────────────────────────────────

    if [[ "${GLOBAL_INSTALL}" == false ]]; then
        step "Updating ignore files"
        append_line "${target_dir}/.gitignore" ".claude/context/" ".gitignore"

        if [[ -f "${target_dir}/Dockerfile" ]] || [[ -f "${target_dir}/docker-compose.yml" ]] || [[ -f "${target_dir}/docker-compose.yaml" ]]; then
            append_line "${target_dir}/.dockerignore" ".claude/context/" ".dockerignore"
        fi
    fi

    # ── Copilot setup (optional) ──────────────────────────────────────────

    if [[ "${SETUP_COPILOT}" == true ]]; then
        step "Setting up GitHub Copilot instructions"

        local github_dir="${target_dir}/.github"
        mkdir -p "${github_dir}/instructions"

        write_file "${github_dir}/copilot-instructions.md" \
            "$(generate_copilot_instructions)" \
            ".github/copilot-instructions.md"

        for lang in "${languages[@]}"; do
            local generator_fn="generate_rule_${lang}"
            if declare -f "${generator_fn}" > /dev/null 2>&1; then
                local copilot_content
                copilot_content="$(convert_rule_to_copilot "$(${generator_fn})")"
                write_file "${github_dir}/instructions/${lang}.instructions.md" \
                    "${copilot_content}" \
                    ".github/instructions/${lang}.instructions.md"
            fi
        done
    fi

    # ── Summary ───────────────────────────────────────────────────────────

    printf "\n"
    printf "  ${GREEN}${BOLD}Setup complete!${RESET}\n\n"

    if [[ "${GLOBAL_INSTALL}" == true ]]; then
        printf "  ${BOLD}Installed to:${RESET}\n"
        printf "    ${DIM}~/.claude/CLAUDE.md${RESET}       ${GRAY}Main instructions${RESET}\n"
        printf "    ${DIM}~/.claude/rules/${RESET}           ${GRAY}Language-specific rules${RESET}\n"
    else
        printf "  ${BOLD}Created:${RESET}\n"
        printf "    ${DIM}CLAUDE.md${RESET}                  ${GRAY}Main instructions (Claude Code reads this)${RESET}\n"
        printf "    ${DIM}.claude/rules/${RESET}              ${GRAY}Language-specific rules${RESET}\n"
        printf "    ${DIM}.claude/context/${RESET}            ${GRAY}Project memory (auto-populated)${RESET}\n"
        if [[ "${SETUP_COPILOT}" == true ]]; then
            printf "    ${DIM}.github/copilot-*.md${RESET}     ${GRAY}Copilot instructions${RESET}\n"
        fi
    fi

    printf "\n  ${BOLD}What happens next:${RESET}\n"
    printf "    ${ARROW} Open this project in VS Code with Claude Code extension\n"
    printf "    ${ARROW} Claude will read CLAUDE.md and .claude/rules/ automatically\n"
    printf "    ${ARROW} On first use, Claude will analyze the codebase and populate .claude/context/\n"

    if [[ "${SETUP_COPILOT}" == false ]] && [[ "${GLOBAL_INSTALL}" == false ]]; then
        printf "\n  ${DIM}Tip: Run with --copilot to also set up GitHub Copilot instructions${RESET}\n"
    fi

    printf "\n  ${GRAY}${INSTALLER_URL}${RESET}\n\n"
}

main "$@"
