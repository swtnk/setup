#!/usr/bin/env bash
# ──────────────────────────────────────────────────────────────────────────────
# Claude Code for VS Code — Project Setup Installer
# https://swetanksubham.com/setup/claude/vscode
#
# Usage:
#   curl -fsSL https://swetanksubham.com/setup/claude/vscode/install | bash
#   curl -fsSL https://swetanksubham.com/setup/claude/vscode/install | bash -s -- --copilot
#   curl -fsSL https://swetanksubham.com/setup/claude/vscode/install | bash -s -- --global
#
# Flags:
#   --copilot     Also set up GitHub Copilot instructions (.github/)
#   --global      Install to ~/.claude/ (global, applies to all projects)
#   --force       Overwrite existing files without prompting
#   --no-detect   Skip language auto-detection, install all language rules
#   --verify      Download and verify checksum, don't install
#   --help        Show help
# ──────────────────────────────────────────────────────────────────────────────

# shellcheck disable=SC2059  # Variables in printf format strings are intentional (ANSI color codes)

set -euo pipefail

# ── Constants ─────────────────────────────────────────────────────────────────

readonly VERSION="2.0.1"
readonly INSTALLER_URL="https://swetanksubham.com/setup/claude/vscode"

# ── Colors & Formatting ──────────────────────────────────────────────────────

if [[ -t 1 ]] && [[ "${NO_COLOR:-}" != "1" ]]; then
    readonly BOLD="\033[1m"
    readonly DIM="\033[2m"
    readonly RESET="\033[0m"
    readonly GREEN="\033[38;2;80;200;120m"
    readonly YELLOW="\033[38;2;255;200;87m"
    readonly RED="\033[38;2;255;99;71m"
    readonly CYAN="\033[38;2;0;206;209m"
    readonly PURPLE="\033[38;2;178;102;255m"
    readonly WHITE="\033[38;2;255;255;255m"
    readonly GRAY="\033[38;2;128;128;128m"
    readonly CHECK="${GREEN}✓${RESET}"
    readonly CROSS="${RED}✗${RESET}"
    readonly ARROW="${CYAN}→${RESET}"
    readonly DOT="${GRAY}·${RESET}"
else
    readonly BOLD="" DIM="" RESET=""
    readonly GREEN="" YELLOW="" RED="" CYAN="" PURPLE="" WHITE="" GRAY=""
    readonly CHECK="✓" CROSS="✗" ARROW="→" DOT="·"
fi

# ── CLI State ─────────────────────────────────────────────────────────────────

SETUP_COPILOT=false
GLOBAL_INSTALL=false
FORCE_OVERWRITE=false
AUTO_DETECT=true
VERIFY_ONLY=false

# ── Helpers ───────────────────────────────────────────────────────────────────

info()    { printf "  ${DOT} %b\n" "$1"; }
success() { printf "  ${CHECK} %b\n" "$1"; }
warn()    { printf "  ${YELLOW}!${RESET} %b\n" "$1"; }
error()   { printf "  ${CROSS} %b\n" "$1" >&2; }
step()    { printf "\n  ${ARROW} ${BOLD}%b${RESET}\n" "$1"; }

toggle_bool_var() {
    local var_name="$1"
    if [[ "${!var_name}" == true ]]; then
        printf -v "${var_name}" "%s" "false"
    else
        printf -v "${var_name}" "%s" "true"
    fi
}

checkbox() {
    local value="$1"
    if [[ "${value}" == true ]]; then
        printf "%b" "${GREEN}[x]${RESET}"
    else
        printf "%b" "${DIM}[ ]${RESET}"
    fi
}

repeat_char() {
    local char="$1"
    local count="$2"
    if (( count <= 0 )); then
        return 0
    fi
    printf "%${count}s" "" | tr ' ' "${char}"
}

banner() {
    local art1_plain="░█▀▀░█░░░█▀█░█░█░█▀▄░█▀▀░█▀▀░█▀█░█▀▄░█▀▀"
    local art2_plain="░█░░░█░░░█▀█░█░█░█░█░█▀▀░█░░░█░█░█░█░█▀▀"
    local art3_plain="░▀▀▀░▀▀▀░▀░▀░▀▀▀░▀▀░░▀▀▀░▀▀▀░▀▀▀░▀▀░░▀▀▀"
    local line4_plain="v${VERSION}"
    local line5_plain="Project Architect Setup"
    local line6_plain="Created By: Swetank Subham"
    local line7_plain="https://swetanksubham.com"

    local art1_rendered="${WHITE}${BOLD}${art1_plain}${RESET}"
    local art2_rendered="${WHITE}${BOLD}${art2_plain}${RESET}"
    local art3_rendered="${WHITE}${BOLD}${art3_plain}${RESET}"
    local line4_rendered="${DIM}${line4_plain}${RESET}"
    local line5_rendered="${DIM}${line5_plain}${RESET}"
    local line6_rendered="${DIM}${line6_plain}${RESET}"
    local line7_rendered="${CYAN}${line7_plain}${RESET}"

    local content_width="${#art1_plain}"
    local art2_len="${#art2_plain}"
    local art3_len="${#art3_plain}"
    local line4_len="${#line4_plain}"
    local line5_len="${#line5_plain}"
    local line6_len="${#line6_plain}"
    local line7_len="${#line7_plain}"

    if (( art2_len > content_width )); then content_width="${art2_len}"; fi
    if (( art3_len > content_width )); then content_width="${art3_len}"; fi
    if (( line4_len > content_width )); then content_width="${line4_len}"; fi
    if (( line5_len > content_width )); then content_width="${line5_len}"; fi
    if (( line6_len > content_width )); then content_width="${line6_len}"; fi
    if (( line7_len > content_width )); then content_width="${line7_len}"; fi

    local inner_width=$((content_width + 4))
    local border
    border="$(repeat_char "═" "${inner_width}")"
    local art1_pad=$((content_width - ${#art1_plain}))
    local art2_pad=$((content_width - ${#art2_plain}))
    local art3_pad=$((content_width - ${#art3_plain}))
    local line4_pad=$((content_width - ${#line4_plain}))
    local line5_pad=$((content_width - ${#line5_plain}))
    local line6_pad=$((content_width - ${#line6_plain}))
    local line7_pad=$((content_width - ${#line7_plain}))

    printf "\n"
    printf "  ${PURPLE}${BOLD}╔%s╗${RESET}\n" "${border}"
    printf "  ${PURPLE}${BOLD}║${RESET}  %b%*s  ${PURPLE}${BOLD}║${RESET}\n" "${art1_rendered}" "${art1_pad}" ""
    printf "  ${PURPLE}${BOLD}║${RESET}  %b%*s  ${PURPLE}${BOLD}║${RESET}\n" "${art2_rendered}" "${art2_pad}" ""
    printf "  ${PURPLE}${BOLD}║${RESET}  %b%*s  ${PURPLE}${BOLD}║${RESET}\n" "${art3_rendered}" "${art3_pad}" ""
    printf "  ${PURPLE}${BOLD}║${RESET}  %b%*s  ${PURPLE}${BOLD}║${RESET}\n" "${line4_rendered}" "${line4_pad}" ""
    printf "  ${PURPLE}${BOLD}║${RESET}  %b%*s  ${PURPLE}${BOLD}║${RESET}\n" "${line5_rendered}" "${line5_pad}" ""
    printf "  ${PURPLE}${BOLD}║${RESET}  %b%*s  ${PURPLE}${BOLD}║${RESET}\n" "${line6_rendered}" "${line6_pad}" ""
    printf "  ${PURPLE}${BOLD}║${RESET}  %b%*s  ${PURPLE}${BOLD}║${RESET}\n" "${line7_rendered}" "${line7_pad}" ""
    printf "  ${PURPLE}${BOLD}╚%s╝${RESET}\n" "${border}"
    printf "\n"
}

show_runtime_options() {
    local enabled="${GREEN}${BOLD}ON${RESET}"
    local disabled="${DIM}off${RESET}"

    local copilot_status="${disabled}"
    local global_status="${disabled}"
    local force_status="${disabled}"
    local no_detect_status="${disabled}"

    if [[ "${SETUP_COPILOT}" == true ]]; then
        copilot_status="${enabled}"
    fi
    if [[ "${GLOBAL_INSTALL}" == true ]]; then
        global_status="${enabled}"
    fi
    if [[ "${FORCE_OVERWRITE}" == true ]]; then
        force_status="${enabled}"
    fi
    if [[ "${AUTO_DETECT}" == false ]]; then
        no_detect_status="${enabled}"
    fi

    printf "  ${BOLD}Options:${RESET}\n"
    printf "    --copilot    %b\n" "${copilot_status}"
    printf "    --global     %b\n" "${global_status}"
    printf "    --force      %b\n" "${force_status}"
    printf "    --no-detect  %b ${DIM}(skip auto-detect languages)${RESET}\n" "${no_detect_status}"
    printf "\n"
}

interactive_select_options() {
    if [[ ! -t 1 ]] || [[ "${CI:-}" == "true" ]] || [[ ! -r /dev/tty ]]; then
        return 0
    fi

    printf "  ${BOLD}Select options (live):${RESET}\n"
    printf "  ${DIM}Press 1-4 to toggle instantly. Press Enter to continue, q to cancel.${RESET}\n\n"
    printf "\033[s"

    while true; do
        printf "\033[u\033[J"

        local copilot_box
        local global_box
        local force_box
        local no_detect_box
        copilot_box="$(checkbox "${SETUP_COPILOT}")"
        global_box="$(checkbox "${GLOBAL_INSTALL}")"
        force_box="$(checkbox "${FORCE_OVERWRITE}")"

        if [[ "${AUTO_DETECT}" == false ]]; then
            no_detect_box="$(checkbox true)"
        else
            no_detect_box="$(checkbox false)"
        fi

        if [[ "${GLOBAL_INSTALL}" == true ]] && [[ "${SETUP_COPILOT}" == true ]]; then
            printf "    1) %b --copilot ${DIM}(skipped with --global)${RESET}\n" "${copilot_box}"
        else
            printf "    1) %b --copilot\n" "${copilot_box}"
        fi
        printf "    2) %b --global\n" "${global_box}"
        printf "    3) %b --force\n" "${force_box}"
        printf "    4) %b --no-detect\n" "${no_detect_box}"
        printf "\n  ${BOLD}Select:${RESET} ${DIM}[1-4 toggle, Enter continue, q cancel]${RESET} "

        local key
        IFS= read -rsn1 key < /dev/tty || true

        if [[ "${key}" == $'\x1b' ]]; then
            IFS= read -rsn2 -t 0.01 _discard < /dev/tty || true
            continue
        fi

        case "${key}" in
            "")
                printf "\n\n"
                break
                ;;
            1)
                toggle_bool_var "SETUP_COPILOT"
                ;;
            2)
                toggle_bool_var "GLOBAL_INSTALL"
                ;;
            3)
                toggle_bool_var "FORCE_OVERWRITE"
                ;;
            4)
                toggle_bool_var "AUTO_DETECT"
                ;;
            q|Q)
                printf "\n\n  ${YELLOW}Cancelled by user.${RESET}\n\n"
                exit 0
                ;;
        esac
    done
}

confirm_if_interactive() {
    if [[ ! -t 1 ]] || [[ ! -r /dev/tty ]]; then
        return 0
    fi

    printf "  ${BOLD}Continue?${RESET} [Y/n] "
    local reply
    read -r reply < /dev/tty || true
    case "${reply:-Y}" in
        [Nn]|[Nn][Oo])
            printf "\n  ${YELLOW}Cancelled by user.${RESET}\n\n"
            exit 0
            ;;
    esac
    printf "\n"
}

run_with_spinner() {
    local message="$1"
    shift

    if [[ ! -t 1 ]] || [[ "${CI:-}" == "true" ]]; then
        "$@"
        return
    fi

    # shellcheck disable=SC1003
    local frames='|/-\'
    local frame_index=0
    local output_file
    output_file="$(mktemp)" || { error "Failed to create temp file"; return 1; }
    local pid

    "$@" >"${output_file}" 2>&1 &
    pid=$!

    while kill -0 "${pid}" 2>/dev/null; do
        local frame="${frames:frame_index:1}"
        printf "\r  ${CYAN}%s${RESET} %b" "${frame}" "${message}" >&2
        frame_index=$(( (frame_index + 1) % 4 ))
        sleep 0.1
    done

    local status=0
    if wait "${pid}"; then
        printf "\r\033[K" >&2
        printf "  ${CHECK} %b\n" "${message}" >&2
    else
        status=$?
        printf "\r\033[K" >&2
        printf "  ${CROSS} %b\n" "${message}" >&2
    fi

    cat "${output_file}"
    rm -f "${output_file}"
    if [[ "${status}" -ne 0 ]]; then
        exit "${status}"
    fi
    return 0
}

verify_integrity() {
    local url="${INSTALLER_URL}/install"
    local checksum_url="${INSTALLER_URL}/install.sha256"

    step "Verifying installer integrity"

    local sha_tool=""
    if command -v sha256sum > /dev/null 2>&1; then
        sha_tool="sha256sum"
    elif command -v shasum > /dev/null 2>&1; then
        sha_tool="shasum -a 256"
    else
        error "No SHA-256 tool found (need sha256sum or shasum)"
        exit 1
    fi

    local tmpdir
    tmpdir="$(mktemp -d)" || { error "Failed to create temp directory"; exit 1; }
    trap 'rm -rf "${tmpdir}"' EXIT

    if ! curl -fsSL "${url}" -o "${tmpdir}/install" 2>/dev/null; then
        error "Failed to download installer from ${url}"
        exit 1
    fi

    if ! curl -fsSL "${checksum_url}" -o "${tmpdir}/install.sha256" 2>/dev/null; then
        error "No checksum file found at ${checksum_url}"
        info "Generate one with: sha256sum install > install.sha256"
        exit 1
    fi

    local expected actual
    expected="$(awk '{print $1}' "${tmpdir}/install.sha256")"
    actual="$(${sha_tool} "${tmpdir}/install" | awk '{print $1}')"

    if [[ "${expected}" == "${actual}" ]]; then
        success "Integrity verified ${DIM}(SHA-256: ${actual:0:16}...)${RESET}"
    else
        error "Checksum mismatch!"
        printf "    Expected: %s\n" "${expected}" >&2
        printf "    Got:      %s\n" "${actual}" >&2
        exit 1
    fi
}

install_rules() {
    local rules_dir="$1"
    local languages_input="$2"
    local rules_label_prefix="$3"

    mkdir -p "${rules_dir}"

    write_file "${rules_dir}/general.md" "$(generate_rule_general)" "${rules_label_prefix}/general.md"

    for lang in ${languages_input}; do
        local generator_fn="generate_rule_${lang}"
        if declare -f "${generator_fn}" > /dev/null 2>&1; then
            write_file "${rules_dir}/${lang}.md" "$(${generator_fn})" "${rules_label_prefix}/${lang}.md"
        fi
    done
}

show_help() {
    banner
    printf "  ${BOLD}Usage:${RESET}\n"
    printf "    curl -fsSL %s/install | bash\n" "${INSTALLER_URL}"
    printf "    curl -fsSL %s/install | bash -s -- [flags]\n\n" "${INSTALLER_URL}"
    printf "  ${BOLD}Flags:${RESET}\n"
    printf "    --copilot     Also set up GitHub Copilot instructions\n"
    printf "    --global      Install to ~/.claude/ (applies to all projects)\n"
    printf "    --force       Overwrite existing files without prompting\n"
    printf "    --no-detect   Skip language detection, install all rules\n"
    printf "    --verify      Verify installer checksum (download-and-check)\n"
    printf "    --version     Show version number\n"
    printf "    --help        Show this help message\n\n"
    exit 0
}

write_file() {
    local filepath="$1"
    local content="$2"
    local label="${3:-$filepath}"

    local dir
    dir="$(dirname "${filepath}")"
    mkdir -p "${dir}"

    if [[ -f "${filepath}" ]] && [[ "${FORCE_OVERWRITE}" == false ]]; then
        warn "Exists: ${DIM}${label}${RESET} ${GRAY}(use --force to overwrite)${RESET}"
        return 0
    fi

    printf '%s\n' "${content}" > "${filepath}"
    success "Created: ${DIM}${label}${RESET}"
}

append_line() {
    local filepath="$1"
    local line="$2"
    local label="${3:-$filepath}"

    if [[ -f "${filepath}" ]]; then
        if grep -qxF "${line}" "${filepath}" 2>/dev/null; then
            info "Already in ${DIM}${label}${RESET}: ${GRAY}${line}${RESET}"
            return 0
        fi
        if [[ -s "${filepath}" ]] && [[ "$(tail -c 1 "${filepath}" | xxd -p)" != "0a" ]]; then
            printf '\n%s\n' "${line}" >> "${filepath}"
        else
            printf '%s\n' "${line}" >> "${filepath}"
        fi
        success "Updated: ${DIM}${label}${RESET} ${GRAY}+ ${line}${RESET}"
    else
        printf '%s\n' "${line}" > "${filepath}"
        success "Created: ${DIM}${label}${RESET} ${GRAY}with ${line}${RESET}"
    fi
}

# ── Language Detection ────────────────────────────────────────────────────────

has_files() {
    # Portable alternative to compgen -G / globstar
    # Uses find with early exit for performance, excludes common non-source directories
    local dir="$1"
    shift
    for pattern in "$@"; do
        if find "${dir}" -maxdepth 6 \
            -not -path '*/.git/*' \
            -not -path '*/node_modules/*' \
            -not -path '*/vendor/*' \
            -not -path '*/build/*' \
            -not -path '*/dist/*' \
            -not -path '*/.cache/*' \
            -name "${pattern}" -print -quit 2>/dev/null | grep -q .; then
            return 0
        fi
    done
    return 1
}

detect_languages() {
    local dir="$1"
    local result=""

    # Python
    if [[ -f "${dir}/pyproject.toml" ]] || \
       [[ -f "${dir}/setup.py" ]] || \
       [[ -f "${dir}/requirements.txt" ]] || \
       [[ -f "${dir}/Pipfile" ]] || \
       [[ -f "${dir}/poetry.lock" ]] || \
       has_files "${dir}" "*.py"; then
        result="${result}python "
    fi

    # Java
    if [[ -f "${dir}/pom.xml" ]] || \
       [[ -f "${dir}/build.gradle" ]] || \
       [[ -f "${dir}/build.gradle.kts" ]] || \
       [[ -d "${dir}/src/main/java" ]] || \
       has_files "${dir}" "*.java"; then
        result="${result}java "
    fi

    # Rust
    if [[ -f "${dir}/Cargo.toml" ]] || \
       has_files "${dir}" "*.rs"; then
        result="${result}rust "
    fi

    # TypeScript
    if [[ -f "${dir}/tsconfig.json" ]] || \
       has_files "${dir}" "*.ts" "*.tsx"; then
        result="${result}typescript "
    fi

    # Go
    if [[ -f "${dir}/go.mod" ]] || \
       has_files "${dir}" "*.go"; then
        result="${result}go "
    fi

    # C/C++
    if [[ -f "${dir}/CMakeLists.txt" ]] || \
       ( [[ -f "${dir}/Makefile" ]] && has_files "${dir}" "*.c" "*.cpp" "*.h" "*.hpp" ) || \
       has_files "${dir}" "*.c" "*.cpp" "*.h" "*.hpp"; then
        result="${result}c_cpp "
    fi

    # Output trimmed result (space-separated)
    printf '%s' "${result% }"
}

# ── Embedded File Contents ────────────────────────────────────────────────────
# All rule files are embedded here so the installer is fully self-contained.
# No additional downloads required.

generate_claude_md() {
cat << 'CLAUDE_MD_EOF'
# Project Architect

Architecture-first code generation. Understand the project fully before writing any code. Coding standards are defined in `.claude/rules/` — this file defines workflow and project memory.

## Before Any Change

**Existing project:** scan the full directory tree, read entry points/configs/build files/env files/CI configs, trace component architecture and data flow, catalog every coding convention (naming, imports, quotes, indentation, patterns), map all constants/config files, identify the full tech stack. Write findings to `.claude/context/`. Match every existing convention exactly — generated code must be indistinguishable from the team's own.

**New project:** understand requirements fully (ask if ambiguous), design architecture and module boundaries, plan constants/config structure, choose dependencies with justification. Populate `.claude/context/` before generating code.

**Resuming:** read all `.claude/context/` files first. Check `progress.md` and `tasklist.md` for where things left off. If the user mentions external changes, re-scan affected areas and update context.

## Project Memory (`.claude/context/`)

Maintain these files, updated after every significant change. Read before writing. Never delete — append and update.

| File | Purpose |
|---|---|
| `architecture.md` | System design, components, data flow, design decisions |
| `conventions.md` | Coding patterns, naming, file organization, imports |
| `progress.md` | What's complete, in progress, pending |
| `constants-map.md` | Config/constants locations and contents |
| `dependencies.md` | Libraries, rationale, version constraints |
| `tasklist.md` | Work items as checkboxes, ordered by dependency |
| `plan.md` | Phases, milestones, delivery strategy, open questions |

## Workflow

1. Decompose non-trivial work into tasks in `tasklist.md` and write the plan in `plan.md` before coding
2. Follow the plan step by step, updating `progress.md` as tasks complete
3. Write tests alongside implementation using the ecosystem's standard framework
4. Check in with the user at milestones and when decisions have trade-offs

## Quality Gate

Before presenting code verify: no hardcoded values, immutable by default, optional types over nulls, standard library used, SOLID followed, self-explanatory naming (no comments), language standards from `.claude/rules/` met, context files updated, tests included, existing patterns matched.
CLAUDE_MD_EOF
}

generate_rule_general() {
cat << 'RULE_EOF'
---
paths:
  - "**"
---

# Universal Coding Standards

## Principles
- SOLID: single responsibility per file/class, open/closed, Liskov substitution, interface segregation, dependency inversion
- Immutable by default: `const`/`final`/`readonly` on all variables, fields, and parameters unless mutation is explicitly justified
- Zero hardcoded values: all constants, magic numbers, URLs, timeouts, feature flags in centralized config files — import everywhere
- No raw nulls: use `Optional`/`Result`/`Option` types — never return or accept null where an optional type exists
- Standard library first: use platform utilities, never reimplement what the language already provides
- Self-explanatory code: descriptive names for everything, no inline/block/doc comments — if it needs a comment, refactor instead. Exceptions: legal headers, TODOs tracked in `tasklist.md`
- Senior engineer quality: right abstraction level, edge cases anticipated, small focused functions, clarity over brevity, passes principal-engineer review
- Match existing codebase: when modifying a project, match every convention exactly — indentation, naming, quotes, imports, patterns, file structure

## Testing
- Write tests alongside implementation, never after
- Unit tests for logic, integration tests for module boundaries
- Test names describe behavior: `should_return_empty_when_no_items` not `test_method`
- Cover edge cases: empty inputs, boundaries, errors, absent values
- Use the ecosystem's standard test framework

## Communication
- When requirements are ambiguous or decisions have trade-offs, stop and ask — present options clearly
- Check in with the user at significant milestones before proceeding
RULE_EOF
}

generate_rule_python() {
cat << 'RULE_EOF'
---
paths:
  - "**/*.py"
---

# Python Standards

- Type hints on all parameters, return types, and variable annotations — no untyped public functions
- `Protocol` for structural subtyping (prefer over ABCs when inheritance isn't needed)
- Full `typing` usage: `Optional`, `Final`, `TypeAlias`, `TypeVar`, `Generic`, `Literal`, `TypedDict`, `Annotated`, `overload`
- `from __future__ import annotations` in every file
- Frozen `@dataclass(frozen=True)` or `NamedTuple` for data containers
- `tuple` over `list` for fixed collections, `Final` for constants
- `Optional[X]` over `X | None` (unless project convention differs)
- Constants in a centralized config/constants module
RULE_EOF
}

generate_rule_java() {
cat << 'RULE_EOF'
---
paths:
  - "**/*.java"
---

# Java Standards

- `java.util.Optional` for absent values; `Objects.isNull()`, `Objects.nonNull()`, `Objects.requireNonNull()` over manual null checks
- Standard library utilities: `Comparator.comparing()`, Stream API, `Collections.unmodifiable*()`, `Map.of()`, `List.of()`
- Lombok: `@Value` (preferred over `@Data`), `@Builder` on classes and records, `@NonNull`, `@Getter`+`@RequiredArgsConstructor` on enums, `@Slf4j`
- `final` on every variable, field, and parameter by default
- Records with `@Builder` for simple data carriers
- Constants in a centralized constants class or config
RULE_EOF
}

generate_rule_rust() {
cat << 'RULE_EOF'
---
paths:
  - "**/*.rs"
---

# Rust Standards

- Prefer borrowing (`&`/`&mut`) over cloning; `mut` only when justified
- `Result<T, E>` for all fallible operations — meaningful error types via `thiserror` or `anyhow`
- No `.unwrap()` or `.expect()` in library/production code — use `?` or explicit matching
- Derive `Clone`, `Debug`, `PartialEq` as appropriate; `#[non_exhaustive]` on public enums/structs
- `impl Trait` in argument position for flexibility; Rust 2024 edition idioms
- Constants in `constants.rs` or `config.rs`; prefer `const` over `static`, `LazyLock` for runtime constants
RULE_EOF
}

generate_rule_typescript() {
cat << 'RULE_EOF'
---
paths:
  - "**/*.ts"
  - "**/*.tsx"
---

# TypeScript Standards

- `"strict": true` in tsconfig — mandatory
- `const` by default, `let` only for reassignment, never `var`
- `readonly` on all properties; `Readonly<T>`, `ReadonlyArray<T>`
- Explicit return types on public/exported functions
- Discriminated unions over loose strings or enums
- `undefined` over `null`; optional chaining (`?.`) and nullish coalescing (`??`)
- Constants in `constants.ts` or `config.ts`; `as const` for literal narrowing
- `unknown` over `any` — if `any` is needed, justify with a comment
RULE_EOF
}

generate_rule_go() {
cat << 'RULE_EOF'
---
paths:
  - "**/*.go"
---

# Go Standards

- Return errors explicitly, never ignore — `errors.Is()`/`errors.As()` for checking, `fmt.Errorf("context: %w", err)` for wrapping
- Value semantics by default; pointers only when mutation is required or structs are large
- Composition via struct embedding; short focused interfaces (1-3 methods) — accept interfaces, return structs
- `const` blocks for related constants; centralized config struct loaded from env or file
- `context.Context` for cancellation and deadline propagation
- Table-driven tests as default pattern
RULE_EOF
}

generate_rule_c_cpp() {
cat << 'RULE_EOF'
---
paths:
  - "**/*.c"
  - "**/*.cpp"
  - "**/*.h"
  - "**/*.hpp"
---

# C/C++ Standards

- `const` by default on variables, parameters, and pointers
- C++: `std::unique_ptr`/`std::shared_ptr` over raw pointers, RAII for all resources
- C++: `std::optional` for absent values, `constexpr` over `#define`, `enum class` over `enum`, `std::string_view` for non-owning references
- C: `const` qualifiers liberally, constants grouped in header files
- `static` for file-scoped functions/variables
- Standard library algorithms (`<algorithm>`, `<numeric>`) over hand-rolled loops
RULE_EOF
}

generate_copilot_instructions() {
cat << 'COPILOT_EOF'
# Copilot Custom Instructions

These instructions apply to all Copilot interactions in this workspace.

## Coding Standards

- SOLID: single responsibility per file/class, open/closed, Liskov substitution, interface segregation, dependency inversion
- Immutable by default: `const`/`final`/`readonly` on all variables, fields, and parameters unless mutation is explicitly justified
- Zero hardcoded values: all constants, magic numbers, URLs, timeouts, feature flags in centralized config files — import everywhere
- No raw nulls: use `Optional`/`Result`/`Option` types — never return or accept null where an optional type exists
- Standard library first: use platform utilities, never reimplement what the language already provides
- Self-explanatory code: descriptive names, no comments — if it needs a comment, refactor instead
- Senior engineer quality: right abstraction level, edge cases anticipated, small focused functions, clarity over brevity
- Match existing codebase conventions exactly when modifying a project

## Testing

- Write tests alongside implementation, never after
- Unit tests for logic, integration tests for module boundaries
- Test names describe behavior, cover edge cases
- Use the ecosystem's standard test framework

## Workflow

- Decompose non-trivial work into small tasks before coding
- Ask when requirements are ambiguous or decisions have trade-offs
- Check in with the user at milestones before proceeding
COPILOT_EOF
}

convert_rule_to_copilot() {
    # Convert paths: (array) to applyTo: (single string) for Copilot
    local content="$1"
    local extensions=""

    # Extract file extensions from paths like **/*.py, **/*.ts, src/**/*.py
    while IFS= read -r line; do
        local ext
        ext="$(printf '%s' "${line}" | sed -n 's/.*- ".*\*\.\([a-zA-Z0-9_]*\)"/\1/p')"
        if [[ -n "${ext}" ]]; then
            if [[ -z "${extensions}" ]]; then
                extensions="${ext}"
            else
                extensions="${extensions},${ext}"
            fi
        fi
    done <<< "${content}"

    # Build applyTo value
    local apply_to="**"
    if [[ -n "${extensions}" ]]; then
        if [[ "${extensions}" == *","* ]]; then
            apply_to="**/*.{${extensions}}"
        else
            apply_to="**/*.${extensions}"
        fi
    fi

    # Strip old frontmatter, output new one + body
    local body
    body="$(printf '%s\n' "${content}" | awk '
        BEGIN { state=0 }
        state==0 && /^---$/ { state=1; next }
        state==1 && /^---$/ { state=2; next }
        state==1 { next }
        state==2 { print }
    ')"

    printf -- '---\napplyTo: "%s"\n---\n%s\n' "${apply_to}" "${body}"
}

# ── Main Install Logic ────────────────────────────────────────────────────────

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --copilot)    SETUP_COPILOT=true ;;
            --global)     GLOBAL_INSTALL=true ;;
            --force)      FORCE_OVERWRITE=true ;;
            --no-detect)  AUTO_DETECT=false ;;
            --verify)     VERIFY_ONLY=true ;;
            --version|-v) printf "Claude Code Setup v%s\n" "${VERSION}"; exit 0 ;;
            --help|-h)    show_help ;;
            *)
                error "Unknown flag: $1"
                printf "  Run with --help for usage.\n"
                exit 1
                ;;
        esac
        shift
    done
}

main() {
    parse_args "$@"

    if [[ "${VERIFY_ONLY}" == true ]]; then
        verify_integrity
        exit 0
    fi

    banner
    interactive_select_options
    show_runtime_options
    confirm_if_interactive

    # ── Determine install target ──────────────────────────────────────────

    local target_dir
    if [[ "${GLOBAL_INSTALL}" == true ]]; then
        target_dir="${HOME}/.claude"
        step "Installing globally to ${CYAN}~/.claude/${RESET}"
    else
        target_dir="$(pwd)"
        step "Setting up project at ${CYAN}${target_dir}${RESET}"
    fi

    # ── Detect languages ──────────────────────────────────────────────────

    languages=""

    if [[ "${GLOBAL_INSTALL}" == true ]] || [[ "${AUTO_DETECT}" == false ]]; then
        languages="python java rust typescript go c_cpp"
        info "Installing all language rules"
    else
        step "Detecting project languages"

        languages="$(run_with_spinner "Scanning project files" detect_languages "${target_dir}")"

        if [[ -z "${languages}" ]]; then
            if [[ -t 1 ]] && [[ "${CI:-}" != "true" ]] && [[ -r /dev/tty ]]; then
                warn "No languages detected."
                printf "  ${BOLD}Select languages to install:${RESET}\n"
                printf "  ${DIM}Press numbers to toggle, Enter to confirm, a for all.${RESET}\n\n"

                local lang_python=false lang_java=false lang_rust=false
                local lang_typescript=false lang_go=false lang_c_cpp=false
                printf "\033[s"

                while true; do
                    printf "\033[u\033[J"
                    printf "    1) %b Python\n" "$(checkbox "${lang_python}")"
                    printf "    2) %b Java\n" "$(checkbox "${lang_java}")"
                    printf "    3) %b Rust\n" "$(checkbox "${lang_rust}")"
                    printf "    4) %b TypeScript\n" "$(checkbox "${lang_typescript}")"
                    printf "    5) %b Go\n" "$(checkbox "${lang_go}")"
                    printf "    6) %b C/C++\n" "$(checkbox "${lang_c_cpp}")"
                    printf "\n  ${BOLD}Select:${RESET} ${DIM}[1-6 toggle, a all, Enter confirm]${RESET} "

                    local lkey
                    IFS= read -rsn1 lkey < /dev/tty || true
                    if [[ "${lkey}" == $'\x1b' ]]; then
                        IFS= read -rsn2 -t 0.01 _discard < /dev/tty || true
                        continue
                    fi
                    case "${lkey}" in
                        "") printf "\n"; break ;;
                        1) toggle_bool_var "lang_python" ;;
                        2) toggle_bool_var "lang_java" ;;
                        3) toggle_bool_var "lang_rust" ;;
                        4) toggle_bool_var "lang_typescript" ;;
                        5) toggle_bool_var "lang_go" ;;
                        6) toggle_bool_var "lang_c_cpp" ;;
                        a|A) lang_python=true; lang_java=true; lang_rust=true
                             lang_typescript=true; lang_go=true; lang_c_cpp=true ;;
                    esac
                done

                languages=""
                [[ "${lang_python}" == true ]] && languages="${languages}python "
                [[ "${lang_java}" == true ]] && languages="${languages}java "
                [[ "${lang_rust}" == true ]] && languages="${languages}rust "
                [[ "${lang_typescript}" == true ]] && languages="${languages}typescript "
                [[ "${lang_go}" == true ]] && languages="${languages}go "
                [[ "${lang_c_cpp}" == true ]] && languages="${languages}c_cpp "
                languages="${languages% }"

                if [[ -z "${languages}" ]]; then
                    warn "No languages selected. Installing all rules."
                    languages="python java rust typescript go c_cpp"
                fi
            else
                warn "No languages detected (empty project). Installing all rules."
                languages="python java rust typescript go c_cpp"
            fi
        else
            for lang in ${languages}; do
                local display_name
                case "${lang}" in
                    c_cpp)      display_name="C/C++" ;;
                    typescript) display_name="TypeScript" ;;
                    python)     display_name="Python" ;;
                    java)       display_name="Java" ;;
                    rust)       display_name="Rust" ;;
                    go)         display_name="Go" ;;
                    *)          display_name="${lang}" ;;
                esac
                success "Found: ${BOLD}${display_name}${RESET}"
            done
        fi
    fi

    # ── Create CLAUDE.md ──────────────────────────────────────────────────

    step "Creating Claude Code configuration"

    if [[ "${GLOBAL_INSTALL}" == true ]]; then
        mkdir -p "${target_dir}"
        # shellcheck disable=SC2088
        write_file "${target_dir}/CLAUDE.md" "$(generate_claude_md)" "~/.claude/CLAUDE.md"
    else
        write_file "${target_dir}/CLAUDE.md" "$(generate_claude_md)" "CLAUDE.md"
    fi

    # ── Create .claude/rules/ ─────────────────────────────────────────────

    local rules_dir
    local rules_label_prefix
    if [[ "${GLOBAL_INSTALL}" == true ]]; then
        rules_dir="${target_dir}/rules"
        # shellcheck disable=SC2088
        rules_label_prefix="~/.claude/rules"
    else
        rules_dir="${target_dir}/.claude/rules"
        rules_label_prefix=".claude/rules"
    fi
    step "Installing coding rules"
    run_with_spinner "Applying rule files" install_rules "${rules_dir}" "${languages}" "${rules_label_prefix}"

    # ── Create .claude/context/ ───────────────────────────────────────────

    if [[ "${GLOBAL_INSTALL}" == false ]]; then
        step "Initializing project memory"

        local context_dir="${target_dir}/.claude/context"
        mkdir -p "${context_dir}"

        local context_readme
        context_readme="$(cat << 'CTX_EOF'
# .claude/context/

This directory is Claude's project memory. It persists understanding across conversations
so Claude never has to re-analyze the codebase from scratch.

## Files

| File | Purpose |
|---|---|
| `architecture.md` | System design, component relationships, data flow |
| `conventions.md` | Coding patterns, naming conventions, style rules |
| `progress.md` | What's complete, in progress, pending |
| `constants-map.md` | Where config/constants live, what they contain |
| `dependencies.md` | Key libraries, why chosen, version constraints |
| `tasklist.md` | Planned work items with checkboxes |
| `plan.md` | Project plan, phases, milestones |

These files are auto-generated and maintained by Claude during development.
This directory is excluded from git and Docker builds.
CTX_EOF
)"
        write_file "${context_dir}/README.md" "${context_readme}" ".claude/context/README.md"
        success "Ready: ${DIM}.claude/context/${RESET} ${GRAY}(Claude will populate on first use)${RESET}"
    fi

    # ── Update .gitignore ─────────────────────────────────────────────────

    if [[ "${GLOBAL_INSTALL}" == false ]]; then
        step "Updating ignore files"
        append_line "${target_dir}/.gitignore" ".claude/context/" ".gitignore"

        if [[ -f "${target_dir}/Dockerfile" ]] || [[ -f "${target_dir}/docker-compose.yml" ]] || [[ -f "${target_dir}/docker-compose.yaml" ]]; then
            append_line "${target_dir}/.dockerignore" ".claude/context/" ".dockerignore"
        fi
    fi

    # ── Copilot setup (optional, project-only) ───────────────────────────

    if [[ "${SETUP_COPILOT}" == true ]] && [[ "${GLOBAL_INSTALL}" == true ]]; then
        warn "Copilot setup is project-only, skipping with --global"
    fi

    if [[ "${SETUP_COPILOT}" == true ]] && [[ "${GLOBAL_INSTALL}" == false ]]; then
        step "Setting up GitHub Copilot instructions"

        local github_dir="${target_dir}/.github"
        mkdir -p "${github_dir}/instructions"

        write_file "${github_dir}/copilot-instructions.md" \
            "$(generate_copilot_instructions)" \
            ".github/copilot-instructions.md"

        for lang in ${languages}; do
            local generator_fn="generate_rule_${lang}"
            if declare -f "${generator_fn}" > /dev/null 2>&1; then
                local copilot_content
                copilot_content="$(convert_rule_to_copilot "$(${generator_fn})")"
                write_file "${github_dir}/instructions/${lang}.instructions.md" \
                    "${copilot_content}" \
                    ".github/instructions/${lang}.instructions.md"
            fi
        done
    fi

    # ── Summary ───────────────────────────────────────────────────────────

    printf "\n"
    printf "  ${GREEN}${BOLD}Setup complete!${RESET}\n\n"

    if [[ "${GLOBAL_INSTALL}" == true ]]; then
        printf "  ${BOLD}Installed to:${RESET}\n"
        printf "    ${DIM}~/.claude/CLAUDE.md${RESET}       ${GRAY}Main instructions${RESET}\n"
        printf "    ${DIM}~/.claude/rules/${RESET}           ${GRAY}Language-specific rules${RESET}\n"
    else
        printf "  ${BOLD}Created:${RESET}\n"
        printf "    ${DIM}CLAUDE.md${RESET}                  ${GRAY}Main instructions (Claude Code reads this)${RESET}\n"
        printf "    ${DIM}.claude/rules/${RESET}              ${GRAY}Language-specific rules${RESET}\n"
        printf "    ${DIM}.claude/context/${RESET}            ${GRAY}Project memory (auto-populated)${RESET}\n"
        if [[ "${SETUP_COPILOT}" == true ]]; then
            printf "    ${DIM}.github/copilot-*.md${RESET}     ${GRAY}Copilot instructions${RESET}\n"
        fi
    fi

    printf "\n  ${BOLD}What happens next:${RESET}\n"
    printf "    ${ARROW} Open this project in VS Code with Claude Code extension\n"
    printf "    ${ARROW} Claude will read CLAUDE.md and .claude/rules/ automatically\n"
    printf "    ${ARROW} On first use, Claude will analyze the codebase and populate .claude/context/\n"

    if [[ "${SETUP_COPILOT}" == false ]] && [[ "${GLOBAL_INSTALL}" == false ]]; then
        printf "\n  ${DIM}Tip: Run with --copilot to also set up GitHub Copilot instructions${RESET}\n"
    fi

    printf "\n  ${GRAY}${INSTALLER_URL}${RESET}\n\n"
}

main "$@"
